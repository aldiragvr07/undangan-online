// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model RSVP {
  id         String   @id @default(cuid())
  name       String
  attendance String
  guests     Int      @default(1)
  message    String?
  createdAt  DateTime @default(now())

  @@map("rsvp")
}
